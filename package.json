{
  "name": "oh_snap_vision",
  "version": "1.0.0-alpha.1",
  "description": "Privacy-conscious Vision MCP with multi-provider support",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "oh_snap": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "keywords": [
    "mcp",
    "vision",
    "oh-snap",
    "privacy",
    "screenshot",
    "image-analysis",
    "kimi",
    "qwen",
    "openai",
    "anthropic",
    "claude",
    "gpt"
  ],
  "author": "mroemore",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mroemore/oh_snap.git"
  },
  "bugs": {
    "url": "https://github.com/mroemore/oh_snap/issues"
  },
  "homepage": "https://github.com/mroemore/oh_snap#readme",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-screenshots": "^0.2.8",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
